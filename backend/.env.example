# ============================================
# STADIUMGPT - Environment Configuration
# ============================================

# --------------------------------------------
# AI & Machine Learning
# --------------------------------------------
# Google Gemini API Key (Required)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Project (Optional)
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI Configuration
VERTEX_AI_ENDPOINT=us-central1-aiplatform.googleapis.com

# --------------------------------------------
# Maps & Location Services
# --------------------------------------------
# Mapbox Token (Required for heatmap)
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_token_here

# Google Maps API Key (Optional)
# Get from: https://console.cloud.google.com/apis/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# PostgreSQL Database (Required)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://stadiumgpt:stadiumgpt123@postgres:5432/stadiumgpt

# Redis Cache (Required for WebSocket & Caching)
# Format: redis://host:port
REDIS_URL=redis://redis:6379

# Redis Password (if enabled)
REDIS_PASSWORD=

# --------------------------------------------
# Firebase Configuration (Optional)
# --------------------------------------------
# Firebase Service Account JSON
# Download from: https://console.firebase.google.com/
FIREBASE_CREDENTIALS=path/to/firebase-credentials.json

# Firebase Project ID
FIREBASE_PROJECT_ID=stadiumgpt-xxxxx

# Firebase Database URL
FIREBASE_DATABASE_URL=https://stadiumgpt-xxxxx-default-rtdb.firebaseio.com/

# --------------------------------------------
# Authentication & Security
# --------------------------------------------
# JWT Secret Key (Required - Generate a secure key)
# Generate using: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_32_chars_minimum

# JWT Algorithm
JWT_ALGORITHM=HS256

# Access Token Expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh Token Expiration (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=12

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
# Allowed Origins (comma-separated)
# For development: *
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# --------------------------------------------
# Application Settings
# --------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=development

# Debug Mode
DEBUG=True

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application Port
PORT=8000

# Host (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# API Version
API_VERSION=1.0.0

# Application Name
APP_NAME=StadiumGPT

# --------------------------------------------
# WebSocket Configuration
# --------------------------------------------
# WebSocket Path
WEBSOCKET_PATH=/ws

# Max WebSocket Connections
WEBSOCKET_MAX_CONNECTIONS=1000

# WebSocket Heartbeat Interval (seconds)
WEBSOCKET_HEARTBEAT_INTERVAL=30

# --------------------------------------------
# Queue Management
# --------------------------------------------
# Queue Update Interval (seconds)
QUEUE_UPDATE_INTERVAL=5

# Max Queue Length Alert Threshold
QUEUE_MAX_THRESHOLD=50

# Queue Prediction Model Path
QUEUE_MODEL_PATH=./models/queue_predictor.pkl

# --------------------------------------------
# Crowd Management
# --------------------------------------------
# Crowd Update Interval (seconds)
CROWD_UPDATE_INTERVAL=10

# Crowd Density Thresholds (0-1)
CROWD_LOW_THRESHOLD=0.3
CROWD_MEDIUM_THRESHOLD=0.6
CROWD_HIGH_THRESHOLD=0.8

# Heatmap Refresh Interval (seconds)
HEATMAP_REFRESH_INTERVAL=5

# --------------------------------------------
# Emergency Settings
# --------------------------------------------
# Emergency Response Time (minutes)
EMERGENCY_RESPONSE_TIME=3

# Emergency Alert Broadcast Channels
EMERGENCY_CHANNELS=medical,security,fire,crowd

# Medical Team Contact
MEDICAL_TEAM_CONTACT=+1234567890

# Security Team Contact
SECURITY_TEAM_CONTACT=+1234567891

# --------------------------------------------
# Transport Settings
# --------------------------------------------
# Transport Update Interval (seconds)
TRANSPORT_UPDATE_INTERVAL=30

# Parking Update Interval (seconds)
PARKING_UPDATE_INTERVAL=60

# Metro API Endpoint (if available)
METRO_API_ENDPOINT=https://api.metro.com/v1/status

# --------------------------------------------
# Email Configuration (Optional)
# --------------------------------------------
# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email From Address
EMAIL_FROM=noreply@stadiumgpt.com

# --------------------------------------------
# SMS Configuration (Optional)
# --------------------------------------------
# Twilio Account SID
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Phone Number
TWILIO_PHONE_NUMBER=+1234567890

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------
# Sentry DSN (Error Tracking)
SENTRY_DSN=your_sentry_dsn

# Prometheus Metrics Port
PROMETHEUS_PORT=9090

# New Relic License Key
NEW_RELIC_LICENSE_KEY=your_new_relic_key

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable AI Features
ENABLE_AI=True

# Enable Voice Recognition
ENABLE_VOICE=True

# Enable Multilingual Support
ENABLE_MULTILINGUAL=True

# Enable Accessibility Features
ENABLE_ACCESSIBILITY=True

# Enable Emergency Features
ENABLE_EMERGENCY=True

# Enable Transport Features
ENABLE_TRANSPORT=True

# Enable Analytics Dashboard
ENABLE_ANALYTICS=True

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
# Rate Limit Requests per Minute
RATE_LIMIT_REQUESTS=60

# Rate Limit Window (seconds)
RATE_LIMIT_WINDOW=60

# --------------------------------------------
# File Uploads
# --------------------------------------------
# Max Upload Size (MB)
MAX_UPLOAD_SIZE=10

# Allowed File Types
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf,.doc,.docx

# Upload Directory
UPLOAD_DIR=./uploads

# --------------------------------------------
# Cache Settings
# --------------------------------------------
# Cache TTL (seconds)
CACHE_TTL=3600

# Cache Max Size (entries)
CACHE_MAX_SIZE=10000

# Session Cache TTL (seconds)
SESSION_CACHE_TTL=86400

# --------------------------------------------
# Development Only
# --------------------------------------------
# Enable Auto-Reload
AUTO_RELOAD=True

# Skip SSL Verification (development only)
SKIP_SSL_VERIFICATION=False

# Enable Debug Endpoints
DEBUG_ENDPOINTS=False

# --------------------------------------------
# Production Settings
# --------------------------------------------
# Use HTTPS
USE_HTTPS=False

# SSL Certificate Path
SSL_CERT_PATH=./certs/cert.pem

# SSL Key Path
SSL_KEY_PATH=./certs/key.pem

# Trusted Proxies (comma-separated IPs)
TRUSTED_PROXIES=127.0.0.1,::1

# --------------------------------------------
# Custom Settings
# --------------------------------------------
# Stadium Name
STADIUM_NAME=FIFA World Cup Stadium

# Stadium Capacity
STADIUM_CAPACITY=80000

# Stadium Timezone
STADIUM_TIMEZONE=UTC

# Default Language
DEFAULT_LANGUAGE=English

# Supported Languages (comma-separated)
SUPPORTED_LANGUAGES=English,Hindi,Spanish,French,Arabic,Japanese

# Emergency Contact Display
EMERGENCY_CONTACT=111